{
  "tasks": {
    "start": "deno run --allow-read --allow-net --allow-write --allow-env main.ts",
    "test": "deno test --allow-read --allow-net --allow-write --allow-env",
    "lint": "deno lint",
    "compile": "deno compile --allow-read --allow-net --allow-write --allow-env ./main.ts --output ../curless"
  },
  "imports": {
    "@std/fmt": "jsr:@std/fmt@^1.0.8",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  }
}
